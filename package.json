{
  "name": "fermi",
  "version": "0.1.0",
  "private": true,
  "author": "Sadia Afrin Purba <purba0101@gmail.com> & Asif Imtiyaz Chowdhury <asif.imch@gmail.com>",
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typegen": "sanity schema extract && sanity typegen generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "spell-check": "cspell \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "markdown-lint": "markdownlint \"**/*.md\" --ignore node_modules",
    "prepare": "husky",
    "purge-all": "tsx scripts/purge-enrollments.ts",
    "migrate:enrollment": "tsx scripts/migrate-enrollment-schema.ts",
    "docker:build": "docker build -t fermi:latest .",
    "docker:build:staging": "docker build -t fermi:staging .",
    "docker:build:production": "docker build -t fermi:production .",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:staging": "docker-compose -f docker-compose.staging.yml up -d",
    "docker:production": "docker-compose -f docker-compose.production.yml up -d",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "rollback:staging": "./scripts/rollback.sh staging",
    "rollback:production": "./scripts/rollback.sh production"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.23.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@sanity/client": "^7.6.0",
    "@sanity/image-url": "^1.1.0",
    "@sanity/preview-url-secret": "^2.1.11",
    "@sanity/vision": "^3.95.0",
    "@sanity/visual-editing": "^2.15.0",
    "@stripe/stripe-js": "^7.4.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express-rate-limit": "^8.0.1",
    "framer-motion": "^11.10.16",
    "groq": "^3.95.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.525.0",
    "next": "^15.3.4",
    "next-sanity": "^9.12.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "prometheus-client": "^0.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.52.1",
    "react-jupyter-notebook": "^0.4.0",
    "react-player": "^3.3.1",
    "sanity": "^3.95.0",
    "sonner": "^1.4.3",
    "stripe": "^18.2.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.4",
    "vercel": "^44.2.12",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "cspell": "^9.2.0",
    "dependency-cruiser": "^17.0.1",
    "dotenv": "^17.2.1",
    "eslint": "^9.30.0",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-unicorn": "^60.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^15.5.2",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.3.3",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
